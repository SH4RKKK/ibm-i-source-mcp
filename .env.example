# ibm-i-source-mcp configuration. Copy to .env (git-ignored).
# Requires mapepire-server running on the IBM i (yum install mapepire-server).

# --- required ---
IBMI_HOST=ibmi.example.com
IBMI_USER=MYUSER
IBMI_PASSWORD=changeme

# --- optional ---
IBMI_MAPEPIRE_PORT=8076        # mapepire daemon port
IBMI_NAMING=system             # system | sql
IBMI_ALLOW_SELF_CERT=true      # accept mapepire self-signed cert
IBMI_SOURCE_FILE_CCSID=37      # EBCDIC page for 65535 columns
IBMI_LOCAL_DIR=ibmi-src        # where local copies are written
