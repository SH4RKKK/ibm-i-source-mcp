# ibm-i-source-mcp configuration. Copy to .env (git-ignored) for the default
# server. For more boxes, add one file each: .env.PROD, .env.DEV, and so on.
# The name after .env. is the server name you pass to the tools' server option
# (list_servers shows them). Connects over SSH and runs the bundled mapepire
# server on the box in single mode, the same way Code for IBM i does. Nothing
# to install on the IBM i.

# --- required ---
IBMI_HOST=ibmi.example.com
IBMI_USER=MYUSER
IBMI_PASSWORD=changeme

# --- optional ---
IBMI_SSH_PORT=22               # SSH port on the IBM i
IBMI_NAMING=system             # system | sql
IBMI_SOURCE_FILE_CCSID=37      # EBCDIC page for 65535 columns
IBMI_LOCAL_DIR=ibmi-src        # where local copies are written
IBMI_MAPEPIRE_JAR=             # override jar path on the box (else the uploaded copy)

# --- safety ---
IBMI_READ_ONLY=false           # true disables upload, compile, and library-list changes (read/search/list only)

# The compile command guard: compile_member only ever runs a create command
# (crt* or runsqlstm). On top of that, any dlt*, clr*, or rmv* command is
# refused, as are these verbs:
#   rgzpfm savlib savobj rstlib rstobj crtusrprf chgusrprf grtobjaut rvkobjaut
#   chgobjown pwrdwnsys endsbs endsys endtcp sbmjob call qsh strqsh strsql
#   rundsql runsql runqry
# Add more of your own here, comma-separated (they are added to the list above):
IBMI_BLOCKED_CL=

# Pin the SSH host key so a changed or spoofed host is refused. Leave blank to
# trust the key on first connect (it is then saved to .ibmi-known-hosts.json).
# To get the value: connect once, then copy the SHA256:... line for your host
# out of .ibmi-known-hosts.json into here. See the README Security section.
IBMI_HOST_FINGERPRINT=
